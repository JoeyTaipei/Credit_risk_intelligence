{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.hg/store/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/env/**": true,
    "**/node_modules/**": true,
    "**/mlruns/**": true,
    "**/outputs/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/.ipynb_checkpoints/**": true,
    "**/*.pkl": true,
    "**/*.joblib": true,
    "**/*.pt": true,
    "**/*.pth": true,
    "**/*.log": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/venv": true,
    "**/env": true,
    "**/node_modules": true,
    "**/mlruns": true,
    "**/outputs": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.ipynb_checkpoints": true,
    "**/*.pkl": true,
    "**/*.joblib": true,
    "**/*.pt": true,
    "**/*.pth": true,
    "**/*.log": true
  },
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.ipynb_checkpoints": true,
    "**/mlruns": true,
    "**/outputs": true
  },
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.analysis.exclude": [
    "**/.venv",
    "**/venv",
    "**/env",
    "**/ENV",
    "**/node_modules",
    "**/mlruns",
    "**/outputs",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.ipynb_checkpoints"
  ],
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.userFileIndexingLimit": 2000,
  "python.terminal.activateEnvironment": true,
  "git.autoRepositoryDetection": "openEditors",
  "git.repositoryScanMaxDepth": 1
}
